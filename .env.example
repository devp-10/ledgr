# Copy this file to .env and uncomment any lines you want to customize.
# Docker Compose automatically reads .env from the directory where you run it.

# ── LLM model ────────────────────────────────────────────────────────────────
# Which Ollama model to use for AI transaction categorization.
# The model is downloaded automatically on first run and cached locally.
#
# Options (all free, run entirely on your machine):
#   mistral      ~4 GB  – fast, good quality (default)
#   llama3.2     ~2 GB  – smaller, slightly lower quality
#   neural-chat  ~4 GB  – alternative option
#
# OLLAMA_MODEL=mistral
